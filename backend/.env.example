# Copy to .env and fill in. Everything defaults to the offline stub.

# --- Extraction provider: "stub" (offline, no API) or "openai" ---
EXTRACTOR=stub

# OpenAI (or OpenAI-compatible) — reads handwriting -> values.
# For the DGX Spark / on-prem swap: set OPENAI_BASE_URL to your vLLM server
# (e.g. http://spark:8000/v1) and OPENAI_MODEL to the local model. No code change.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5            # set your exact GPT-5.x vision model id

# --- OCR provider (bounding boxes + per-word confidence) ---
# "stub" | "mistral" | "azure" | "google"
OCR_ENGINE=stub
MISTRAL_API_KEY=             # Mistral OCR 4
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=
GOOGLE_OCR_PROCESSOR=

# --- Database (swap to Postgres/Supabase by changing this one value) ---
DATABASE_URL=sqlite:///./biodize.db

# --- Pipeline ---
STORAGE_DIR=./var
RENDER_DPI=200
AUTO_ACCEPT_THRESHOLD=0.9
VERIFICATION_POLICY=confidence_gated   # or "verify_everything"
