# Base URL of the BioDize FastAPI backend (no trailing slash).
# Leave unset to use the built-in default; override at runtime via the in-app
# API settings (gear icon) which persists to localStorage.
#
# Examples:
#   VITE_API_BASE=https://api.biodize.tech
#   VITE_API_BASE=https://<your-tunnel>.trycloudflare.com
#   VITE_API_BASE=http://localhost:8000
VITE_API_BASE=https://interfaces-offices-listings-whenever.trycloudflare.com
